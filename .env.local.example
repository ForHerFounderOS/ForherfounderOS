AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=

# Daily brief cron (app/api/cron/daily-brief)
# Resend free tier (https://resend.com) — no card required. Get an API key
# from the dashboard.
RESEND_API_KEY=
# Recipient — defaults to Valerie.ayeni@icloud.com if unset.
BRIEF_EMAIL=
# Sender — defaults to Resend's shared sandbox address if unset, which (absent
# a verified sending domain) can only deliver to the email the Resend account
# was signed up with. Verify a domain in Resend to send to any recipient.
RESEND_FROM=
# Any random string — Vercel sends it back as `Authorization: Bearer <value>`
# on real cron firings so the endpoint can reject everyone else. Generate one
# with e.g. `openssl rand -hex 32`.
CRON_SECRET=

# Calendar Intelligence + daily brief (app/api/calendar, app/api/cron/daily-brief)
# Comma-separated "Secret address in iCal format" URLs, one per calendar
# (Google Calendar > each calendar > Settings and sharing > Integrate calendar).
# Each URL is itself a bearer credential — keep it out of client code same as
# everything else here.
CALENDAR_ICS_URLS=
